// apps/api/prisma/schema.prisma
// SQLite-compatible MVP schema (no enums; use String + defaults)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Allowed values (enforced in app layer for SQLite):
// - Entity.status: "ACTIVE" | "INACTIVE"
// - FilingObligation.frequency: "MONTHLY" | "QUARTERLY" | "ANNUAL"
// - FilingPeriod.status: "NOT_STARTED" | "IN_PROGRESS" | "UNDER_REVIEW" | "FILED" | "EXTENDED" | "NOT_APPLICABLE"

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   @default("USER") // ADMIN | MANAGER | PREPARER | REVIEWER | READONLY
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedEntities          Entity[]           @relation("EntityOwner")
  responsibleObligations FilingObligation[] @relation("ObligationResponsible")
  assignedPeriods        FilingPeriod[]     @relation("PeriodAssignee")
  uploadedDocuments      Document[]         @relation("DocumentUploader")
}

model Entity {
  id           String   @id @default(cuid())
  name         String
  shortName    String?
  entityType   String
  jurisdiction String
  taxYearEnd   String?
  status       String   @default("ACTIVE")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerUserId  String?
  owner        User?    @relation("EntityOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  obligations  FilingObligation[]
  documents    Document[]
}

model FilingObligation {
  id                    String   @id @default(cuid())
  entityId              String
  filingName            String
  jurisdiction          String
  frequency             String
  dueDaysAfterPeriodEnd Int      @default(30)
  active                Boolean  @default(true)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  responsibleUserId     String?
  responsibleUser       User?    @relation("ObligationResponsible", fields: [responsibleUserId], references: [id], onDelete: SetNull)

  entity                Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  periods               FilingPeriod[]
}

model FilingPeriod {
  id           String   @id @default(cuid())
  obligationId String
  periodStart  DateTime
  periodEnd    DateTime
  dueDate      DateTime

  status       String   @default("NOT_STARTED")
  assignedToId String?
  assignedTo   User?    @relation("PeriodAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  filedDate          DateTime?
  confirmationNumber String?
  notes              String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  obligation   FilingObligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)
  documents    Document[]

  @@index([obligationId])
  @@index([dueDate])
  @@index([status])
}

model Document {
  id             String   @id @default(cuid())
  fileName       String
  mimeType       String?
  filePath       String
  sizeBytes      Int?
  uploadedAt     DateTime @default(now())

  uploadedById   String?
  uploadedBy     User?    @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  entityId       String?
  entity         Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)

  filingPeriodId String?
  filingPeriod   FilingPeriod? @relation(fields: [filingPeriodId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([filingPeriodId])
  @@index([uploadedAt])
}