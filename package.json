{
  "name": "tax-compliance-mvp",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "concurrently -n api,web -c auto \"pnpm --filter api dev\" \"pnpm --filter web dev\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "api:prisma:generate": "pnpm --filter api prisma generate",
    "api:migrate": "pnpm --filter api prisma migrate dev",
    "api:seed": "pnpm --filter api prisma db seed",
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}